---
layout: none
---
[
{%- assign first = true -%}
{%- for item in site.data.agents -%}
{%- unless first -%},{%- endunless -%}
{%- assign first = false -%}
{%- assign item_id = "agent-" | append: item.name | append: "-" | append: item.title | slugify -%}
{"title":{{ item.title | jsonify }},"url":{{ site.baseurl | append: '/agents/#item=' | append: item_id | jsonify }},"type":"agent","content":{{ item.description | append: " " | append: item.usage | append: " " | append: item.code | strip_html | jsonify }}}
{%- endfor -%}
{%- for item in site.data.slash_commands -%}
{%- assign item_id = "slash-command-" | append: item.name | append: "-" | append: item.title | slugify -%}
,{"title":{{ item.title | jsonify }},"url":{{ site.baseurl | append: '/slash-commands/#item=' | append: item_id | jsonify }},"type":"slash-command","content":{{ item.description | append: " " | append: item.usage | append: " " | append: item.code | strip_html | jsonify }}}
{%- endfor -%}
{%- for item in site.data.hooks -%}
{%- assign item_id = "hook-" | append: item.title | slugify -%}
,{"title":{{ item.title | jsonify }},"url":{{ site.baseurl | append: '/hooks/#item=' | append: item_id | jsonify }},"type":"hook","content":{{ item.description | append: " " | append: item.event | append: " " | append: item.code | strip_html | jsonify }}}
{%- endfor -%}
{%- for item in site.data.skills -%}
{%- assign item_id = "skill-" | append: item.name | append: "-" | append: item.title | slugify -%}
,{"title":{{ item.title | jsonify }},"url":{{ site.baseurl | append: '/skills/#item=' | append: item_id | jsonify }},"type":"skill","content":{{ item.description | append: " " | append: item.usage | append: " " | append: item.code | strip_html | jsonify }}}
{%- endfor -%}
]
